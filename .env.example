# Copy to .env and fill in real values: cp .env.example .env

# Claude — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Deepgram — https://console.deepgram.com/
DEEPGRAM_API_KEY=

# Optional: timezone for calendar events (defaults to America/Los_Angeles)
LOCAL_TIMEZONE=America/Los_Angeles

BROWSERBASE_PROJECT_ID=
BROWSERBASE_API_KEY=

# --- Agentic intent router (src/server.ts <- agent.py via router_client.py) ---
# Where the Python pipeline sends intent strings. Default works for local dev.
ROUTER_URL=http://localhost:8788
# ROUTER_PORT=8788          # port src/server.ts listens on

# The Browserbase tier uses ANTHROPIC_API_KEY directly — no extra key needed.
# Optional tiers (router falls through gracefully if these are unset):
#   AGENTVERSE_API_KEY              — Fetch.ai agent discovery tier
#   LLM_API_KEY/LLM_BASE_URL/LLM_MODEL — OpenAI-compatible key for the calendar
#                                    planner + Agentverse confidence gate
AGENTVERSE_API_KEY=
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
